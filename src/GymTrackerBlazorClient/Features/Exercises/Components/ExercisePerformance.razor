@using ApexCharts
@using GymTracker.Domain.Models
@using GymTracker.Domain.Models.Extensions
@using GymTracker.Domain.Models.Statistics

@if (Statistic is null || !Statistic.Logs.Any())
{
    <MudText Typo="Typo.subtitle1" Class="mt-4" Align="MudBlazor.Align.Center">No workout history for this exercise yet</MudText>
}
else
{
    <div class="d-flex flex-column gap-3">
        <MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.subtitle1" Class="mb-2"><b>Records</b></MudText>

            @switch (MetricType)
            {
                case MetricType.Weight:
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Best Set</MudText>
                        <MudText Typo="Typo.body2"><b>@BestSet</b></MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Heaviest Weight</MudText>
                        <MudText Typo="Typo.body2"><b>@HeaviestWeight</b></MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Max Session Volume</MudText>
                        <MudText Typo="Typo.body2"><b>@MaxSessionVolume</b></MudText>
                    </div>
                    break;

                case MetricType.Reps:
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Best Set</MudText>
                        <MudText Typo="Typo.body2"><b>@BestSet</b></MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Max Session Total</MudText>
                        <MudText Typo="Typo.body2"><b>@MaxSessionVolume</b></MudText>
                    </div>
                    break;

                case MetricType.Time:
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Longest Set</MudText>
                        <MudText Typo="Typo.body2"><b>@BestSet</b></MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Max Session Total</MudText>
                        <MudText Typo="Typo.body2"><b>@MaxSessionVolume</b></MudText>
                    </div>
                    break;

                case MetricType.TimeAndDistance:
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Longest Distance</MudText>
                        <MudText Typo="Typo.body2"><b>@BestSet</b></MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Max Session Volume</MudText>
                        <MudText Typo="Typo.body2"><b>@MaxSessionVolume</b></MudText>
                    </div>
                    break;
            }

            <div class="d-flex justify-space-between mt-1">
                <MudText Typo="Typo.body2">Workouts</MudText>
                <MudText Typo="Typo.body2"><b>@Statistic.Logs.Count</b></MudText>
            </div>
        </MudPaper>

        <MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.subtitle2" Class="mb-1">Volume Over Time</MudText>
            <ApexChart TItem="ExerciseLog"
                       XAxisType="XAxisType.Datetime"
                       Options="VolumeChartOptions">
                <ApexPointSeries TItem="ExerciseLog"
                                 Items="Statistic.Logs"
                                 Name="Volume"
                                 SeriesType="SeriesType.Line"
                                 XValue="@(e => e.WorkoutDateTime)"
                                 YValue="@(e => e.TotalVolume)"
                                 OrderByDescending="x => x.X" />
            </ApexChart>
        </MudPaper>

        <MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.subtitle2" Class="mb-1">Max Effort Over Time</MudText>
            <ApexChart TItem="MaxEffortPoint"
                       XAxisType="XAxisType.Datetime"
                       Options="EffortChartOptions">
                <ApexPointSeries TItem="MaxEffortPoint"
                                 Items="MaxEffortData"
                                 Name="Max Effort"
                                 SeriesType="SeriesType.Line"
                                 XValue="@(e => e.Date)"
                                 YValue="@(e => e.Value)"
                                 OrderByDescending="x => x.X" />
            </ApexChart>
        </MudPaper>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public ExerciseStatistic? Statistic { get; set; }

    [Parameter, EditorRequired]
    public MetricType MetricType { get; set; }

    private record MaxEffortPoint(DateTimeOffset Date, decimal Value);

    private string BestSet =>
        Statistic?.Logs
            .SelectMany(l => l.Sets)
            .GetMaxSet(MetricType)
            ?.ToFormattedMetric(MetricType) ?? "-";

    private string HeaviestWeight =>
        Statistic?.Logs
            .SelectMany(l => l.Sets)
            .Max(s => s.Weight ?? 0)
            .ToString() + " Kg";

    private string MaxSessionVolume =>
        Statistic?.Logs
            .Max(l => l.TotalVolume)
            .ToString()
            .WithFormattedMetricMeasureMetric(MetricType) ?? "-";

    private ICollection<MaxEffortPoint> MaxEffortData =>
        Statistic?.Logs
            .Select(log => new MaxEffortPoint(
                log.WorkoutDateTime,
                log.Sets.GetMaxSet(MetricType)?.ToStandardMeasure(MetricType) ?? 0))
            .ToList()
        ?? new List<MaxEffortPoint>();

    private ApexChartOptions<ExerciseLog> VolumeChartOptions => new()
    {
        Chart = new Chart
        {
            Background = "#32333d",
            Toolbar = new Toolbar { Show = false },
            ForeColor = "#fff",
            Width = "100%",
            Height = "200px"
        },
        Colors = new List<string> { "#77B6EA" }
    };

    private ApexChartOptions<MaxEffortPoint> EffortChartOptions => new()
    {
        Chart = new Chart
        {
            Background = "#32333d",
            Toolbar = new Toolbar { Show = false },
            ForeColor = "#fff",
            Width = "100%",
            Height = "200px"
        },
        Colors = new List<string> { "#E57373" }
    };
}
