@using GymTracker.BlazorClient.Features.Common.FullHeightList
@using GymTracker.BlazorClient.Features.Common;
@using GymTracker.BlazorClient.Features.SidePanel;
@using GymTracker.BlazorClient.Features.WorkoutPlans.Store;
@using GymTracker.BlazorClient.Features.Common.ExercisePicker.Components;
@using System.Collections.Immutable;
@using GymTracker.Domain.Models;

@inject IDispatcher Dispatcher
@inject SidePanelService SidePanelService
@inject IDialogService DialogService

<MudPaper Class="pa-2">
    <MudForm @ref="_form">
        <MudStack Class="fullHeight ma-0">
            <MudTextField @bind-Value="_workoutPlanName"
                          For="@(() => _workoutPlanName)"
                          Immediate="true"
                          DebounceInterval="500"
                          OnDebounceIntervalElapsed="HandleUpdateWorkoutPlan"
                          Label="Workout Plan Name"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Workout Plan Name required!">
            </MudTextField>

            <MudRadioGroup T="WorkoutType" Value="_workoutType" ValueChanged="HandleWorkoutTypeChanged">
                <MudRadio T="WorkoutType" Value="WorkoutType.Standard" Color="Color.Primary">Standard</MudRadio>
                <MudRadio T="WorkoutType" Value="WorkoutType.Circuit" Color="Color.Primary">Circuit</MudRadio>
            </MudRadioGroup>

            @if (_workoutType == WorkoutType.Circuit)
            {
                <CircuitPlanBody WorkoutPlanDetail="WorkoutPlanDetail"
                                 SelectedExerciseId="SelectedExerciseId"
                                 OnExerciseSelected="OnExerciseSelected" />
            }
            else
            {
                <StandardPlanBody WorkoutPlanDetail="WorkoutPlanDetail"
                                  SelectedExerciseId="SelectedExerciseId"
                                  OnExerciseSelected="OnExerciseSelected" />
            }

            <MudSwitch T="bool" Value="_isActive"
                       Label="Is Active"
                       LabelPlacement="Placement.Start"
                       ValueChanged="(bool isActive) => HandleIsActiveChanged(isActive)" />
            <MudSwitch T="bool" Value="_isRegularRoutine"
                       Label="Regular Routine"
                       LabelPlacement="Placement.Start"
                       ValueChanged="(bool value) => HandleIsRegularRoutineChanged(value)" />
        </MudStack>
    </MudForm>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public WorkoutPlanDetail WorkoutPlanDetail { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventCallback<WorkoutPlanDetail> OnWorkoutPlanUpdated { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<ListItem> OnExerciseSelected { get; set; }

    [Parameter, EditorRequired]
    public Guid? SelectedExerciseId { get; set; } = null;

    MudForm _form = default!;
    string _workoutPlanName = string.Empty;
    bool _isActive = true;
    bool _isRegularRoutine = false;
    WorkoutType _workoutType = WorkoutType.Standard;

    protected override async Task OnParametersSetAsync()
    {
        _workoutPlanName = WorkoutPlanDetail.Name;
        _isActive = WorkoutPlanDetail.IsActive;
        _isRegularRoutine = WorkoutPlanDetail.IsRegularRoutine;
        _workoutType = WorkoutPlanDetail.WorkoutType;

        if (_form is not null) await _form.ResetValidationAsync();

        await base.OnParametersSetAsync();
    }

    async Task HandleUpdateWorkoutPlan()
    {
        await _form.ValidateAsync();

        if (!_form.IsValid)
            return;

        var updateDTO = WorkoutPlanDetail with
            {
                Name = _workoutPlanName,
                IsActive = _isActive,
                IsRegularRoutine = _isRegularRoutine
            };

        await OnWorkoutPlanUpdated.InvokeAsync(updateDTO);
    }

    async Task HandleWorkoutTypeChanged(WorkoutType newType)
    {
        if (newType == _workoutType) return;

        if (WorkoutPlanDetail.PlannedExercises.Length > 0)
        {
            var parameters = new DialogParameters<ConfirmDialog>
            {
                { x => x.Title, "Change workout type?" },
                { x => x.Message, "Switching type will remove all current exercises. Continue?" },
                { x => x.ConfirmText, "Yes, switch" }
            };
            var dialog = await DialogService.ShowAsync<ConfirmDialog>("", parameters);
            var result = await dialog.Result;
            if (result?.Canceled ?? true) return;
        }

        _workoutType = newType;
        Dispatcher.Dispatch(new SetWorkoutPlanTypeAction(WorkoutPlanDetail.Id, newType));
    }

    async Task HandleIsActiveChanged(bool isActive)
    {
        _isActive = isActive;
        await HandleUpdateWorkoutPlan();
    }

    async Task HandleIsRegularRoutineChanged(bool value)
    {
        _isRegularRoutine = value;
        await HandleUpdateWorkoutPlan();
    }
}
