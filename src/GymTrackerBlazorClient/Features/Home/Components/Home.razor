@page "/"

@using Fluxor
@using GymTracker.BlazorClient.Features.AppBar.Store;
@using GymTracker.BlazorClient.Features.Home.Components.WorkoutHistory
@using GymTracker.BlazorClient.Features.Home.Store
@using GymTracker.BlazorClient.Features.Workout.Perform.Store;

@inject IDispatcher Dispatcher
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="d-flex flex-row fullWidth fullHeight">
    <div class="pa-3 d-flex flex-column fullHeight" style="width: 65%; height: 30%;">
        <div class="pa-3 d-flex flex-row flex-wrap gap-4 fullWidth">
            <Buttons></Buttons>
        </div>
        <div class="pa-3 d-flex flex-row flex-wrap fullHeight fullWidth gap-4">
            <Charts></Charts>
        </div>
    </div>
    <div class="py-3 fullHeight" style="width: 35%">
        <WorkoutHistory></WorkoutHistory>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var isMobile = await JS.InvokeAsync<bool>("eval", "window.__isMobile");
        if (isMobile)
        {
            NavigationManager.NavigateTo("/mobile");
            return;
        }

        Dispatcher.Dispatch(new ResetBreadcrumbsToHomeAction());
        Dispatcher.Dispatch(new InitaliseHomeAction());
    }
}