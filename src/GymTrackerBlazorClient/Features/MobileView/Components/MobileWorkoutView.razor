@page "/mobile"
@using GymTracker.Domain.Models
@using GymTracker.Domain.Models.Statistics
@using GymTracker.BlazorClient.Features.Home.Components.WorkoutHistory
@using GymTracker.BlazorClient.Features.AppBar.Store

@inject HttpClient Http
@inject IJSRuntime JS
@inject IActionSubscriber ActionSubscriber

@implements IDisposable

<PageTitle>Workout History</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="pa-2">

    @if (_settingsOpen)
    {
        <MudPaper Class="pa-3 mb-3" Elevation="1">
            <MudTextField
                @bind-Value="_sasUri"
                Label="Azure Blob Container SAS URI"
                Variant="Variant.Outlined"
                InputType="@(_showSasUri ? InputType.Text : InputType.Password)"
                Adornment="Adornment.End"
                AdornmentIcon="@(_showSasUri ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                OnAdornmentClick="() => _showSasUri = !_showSasUri"
                Class="mb-2" />
            <MudButton
                Variant="Variant.Filled"
                Color="Color.Primary"
                FullWidth="true"
                Disabled="@(string.IsNullOrWhiteSpace(_sasUri))"
                OnClick="SaveAndLoad">
                Save &amp; Load
            </MudButton>
        </MudPaper>
    }

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }

    @if (_error is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
    }

    @if (_nextWorkout is not null)
    {
        <MudText Typo="Typo.subtitle1" Class="mb-1">Upcoming</MudText>
        <UpcomingWorkout Summary="_nextWorkout" />
    }

    @if (_workouts is not null)
    {
        <MudText Typo="Typo.subtitle1" Class="mb-1">Previous</MudText>
        @foreach (var workout in _workouts)
        {
            <MudPaper Class="pa-3 mb-2" Elevation="1" Style="cursor:pointer;" @onclick="() => HandleWorkoutTap(workout)">
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.subtitle2">@workout.WorkoutPlanName</MudText>
                    <MudText Typo="Typo.subtitle2">@workout.CompletedOn.ToString("dd/MM/yy HH:mm")</MudText>
                </div>
                @WorkoutView(workout)
            </MudPaper>
        }
    }

</MudContainer>

<MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.Bottom" Elevation="4"
           Variant="DrawerVariant.Temporary" ClipMode="DrawerClipMode.Never"
           Style="height:80vh;">
    <WorkoutDetailSheet
        Stat="_selectedWorkout"
        Detail="_selectedWorkoutDetail"
        IsLoading="_loadingDetail"
        Error="@_detailError"
        OnClose="() => _drawerOpen = false" />
</MudDrawer>

@code {
    private string? _sasUri;
    private WorkoutStatistic[]? _workouts;
    private Workout[]? _allWorkouts;
    private NextWorkoutSummary? _nextWorkout;
    private bool _isLoading;
    private string? _error;
    private bool _settingsOpen = true;
    private bool _showSasUri;

    private bool _drawerOpen;
    private bool _loadingDetail;
    private string? _detailError;
    private WorkoutStatistic? _selectedWorkout;
    private Workout? _selectedWorkoutDetail;

    private const string StorageKey = "MobileSasUri";
    private const string BlobKey = "WorkoutStatistics";
    private const string WorkoutsBlobKey = "Workouts";
    private const string NextWorkoutBlobKey = "NextWorkoutSummary";

    protected override void OnInitialized()
    {
        ActionSubscriber.SubscribeToAction<ToggleMobileSettingsAction>(this, _ =>
        {
            _settingsOpen = !_settingsOpen;
            StateHasChanged();
        });
    }

    protected override async Task OnInitializedAsync()
    {
        _sasUri = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);
        if (!string.IsNullOrWhiteSpace(_sasUri))
        {
            _settingsOpen = false;
            await FetchWorkouts();
        }
    }

    private async Task SaveAndLoad()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, _sasUri);
        _settingsOpen = false;
        _allWorkouts = null; // reset cache when SAS URI changes
        await FetchWorkouts();
    }

    private async Task FetchWorkouts()
    {
        if (string.IsNullOrWhiteSpace(_sasUri)) return;

        _isLoading = true;
        _error = null;
        _workouts = null;
        _nextWorkout = null;

        try
        {
            var uri = new Uri(_sasUri);
            var url = $"{uri.Scheme}://{uri.Host}{uri.AbsolutePath}/{Uri.EscapeDataString(BlobKey)}{uri.Query}";

            var workoutsRequest = new HttpRequestMessage(HttpMethod.Get, url);
            workoutsRequest.SetBrowserRequestCache(BrowserRequestCache.NoCache);
            var workoutsResponse = await Http.SendAsync(workoutsRequest);
            workoutsResponse.EnsureSuccessStatusCode();
            _workouts = await workoutsResponse.Content.ReadFromJsonAsync<WorkoutStatistic[]>();
            _workouts = _workouts?
                .OrderByDescending(x => x.CompletedOn)
                .Take(20)
                .ToArray();

            try
            {
                var nextUrl = $"{uri.Scheme}://{uri.Host}{uri.AbsolutePath}/{Uri.EscapeDataString(NextWorkoutBlobKey)}{uri.Query}";
                var nextRequest = new HttpRequestMessage(HttpMethod.Get, nextUrl);
                nextRequest.SetBrowserRequestCache(BrowserRequestCache.NoCache);
                var nextResponse = await Http.SendAsync(nextRequest);
                nextResponse.EnsureSuccessStatusCode();
                _nextWorkout = await nextResponse.Content.ReadFromJsonAsync<NextWorkoutSummary>();
            }
            catch
            {
                _nextWorkout = null; // optional — silently skip if blob doesn't exist yet
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load workouts: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadFullWorkouts()
    {
        if (_allWorkouts is not null) return;
        var uri = new Uri(_sasUri!);
        var url = $"{uri.Scheme}://{uri.Host}{uri.AbsolutePath}/{Uri.EscapeDataString(WorkoutsBlobKey)}{uri.Query}";
        var request = new HttpRequestMessage(HttpMethod.Get, url);
        request.SetBrowserRequestCache(BrowserRequestCache.NoCache);
        var response = await Http.SendAsync(request);
        response.EnsureSuccessStatusCode();
        _allWorkouts = await response.Content.ReadFromJsonAsync<Workout[]>();
    }

    private async Task HandleWorkoutTap(WorkoutStatistic stat)
    {
        _loadingDetail = true;
        _drawerOpen = true;
        _selectedWorkout = stat;
        _selectedWorkoutDetail = null;
        _detailError = null;
        StateHasChanged();

        try
        {
            await LoadFullWorkouts();
            _selectedWorkoutDetail = _allWorkouts?.FirstOrDefault(w => w.Id == stat.WorkoutId);
        }
        catch (Exception ex)
        {
            _detailError = $"{ex.GetType().Name}: {ex.Message}\n{ex.InnerException?.Message}";
            await JS.InvokeVoidAsync("console.error", "Workout detail error", ex.ToString());
        }
        finally
        {
            _loadingDetail = false;
            StateHasChanged();
        }
    }

    private RenderFragment WorkoutView(WorkoutStatistic workout) =>
        workout.IsRepsOnly && workout.Exercises.Count() == 1
            ? @<SingleExerciseReps WorkoutStatistic="workout" />
            : @<StandardExercises WorkoutStatistic="workout" />;

    public void Dispose() => ActionSubscriber.UnsubscribeFromAllActions(this);
}
