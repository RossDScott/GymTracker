@using GymTracker.BlazorClient.Features.AppBar.Components
@using GymTracker.BlazorClient.Features.SidePanel.Components
@using GymTracker.BlazorClient.Shared.Store;
@inherits LayoutComponentBase
@implements IDisposable

@inject IDispatcher Dispatcher
@inject ISnackbar Snackbar
@inject ErrorService ErrorService

<MudThemeProvider @ref="@_mudThemeProvider" Theme="MyCustomTheme" @bind-IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (_serviceException is not null)
{
    <ErrorDisplay Exception="_serviceException" OnRecover="RecoverFromServiceError" />
}
else
{
    <MudLayout Class="fullHeight fullWidth" @onclick="() => Dispatcher.Dispatch(new UnhandledClickAction())">
        <AppBar></AppBar>
        <MudMainContent Class="fullHeight fullWidth mt-n16 pt-16">
            <MudContainer MaxWidth="MaxWidth.Large" Class="ma-0 pa-0 fullHeight fullWidth">
                <ErrorBoundary @ref="_errorBoundary">
                    <ChildContent>@Body</ChildContent>
                    <ErrorContent Context="exception">
                        <ErrorDisplay Exception="exception" OnRecover="RecoverFromBoundaryError" />
                    </ErrorContent>
                </ErrorBoundary>
            </MudContainer>
        </MudMainContent>

        <SidePanel></SidePanel>
    </MudLayout>
}

@code {
    private bool _isDarkMode;
    private MudThemeProvider _mudThemeProvider = new();
    private ErrorBoundary? _errorBoundary;
    private Exception? _serviceException;

    MudTheme MyCustomTheme = new MudTheme()
    {
        Typography = new Typography
        {
            Subtitle1 = new Subtitle1Typography {FontSize = "1.1rem;"},
            Subtitle2 = new Subtitle2Typography {FontSize = "0.9rem;"}
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();

            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
            Snackbar.Configuration.ClearAfterNavigation = true;
            Snackbar.Configuration.VisibleStateDuration = 3000;

            ErrorService.OnErrorChanged += OnServiceErrorChanged;

            StateHasChanged();
        }
    }

    private void OnServiceErrorChanged()
    {
        _serviceException = ErrorService.CurrentException;
        InvokeAsync(StateHasChanged);
    }

    private void RecoverFromBoundaryError()
    {
        _errorBoundary?.Recover();
    }

    private void RecoverFromServiceError()
    {
        ErrorService.ClearException();
    }

    public void Dispose()
    {
        ErrorService.OnErrorChanged -= OnServiceErrorChanged;
    }
}
